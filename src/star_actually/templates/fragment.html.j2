<article class="node" id="content"
  data-node-id="{{ node.id }}"
  data-depth="{{ depth }}"
  data-max-depth="{{ node.depth_levels }}"
  data-title="{{ node.title }}">

  <header class="node-head">
    <div class="node-title-line">
      <h1 class="node-title">{{ node.title }}</h1>
      <span class="node-type node-type-{{ node.type.value }}">{{ node.type.value }}</span>
    </div>
    <div class="depth-dial">
      {# Depth 1 is the name — it is the title above. The dial reads the body
         layers (depths 2..N), shown to the reader as 1..N-1. #}
      <span class="depth-gauge" aria-label="reading level {{ [depth - 1, 1] | max }} of {{ node.depth_levels - 1 }}">
        {%- for d in range(2, node.depth_levels + 1) -%}
        <span class="gauge-cell{% if d <= depth %} lit{% endif %}"></span>
        {%- endfor -%}
      </span>
      <span class="depth-label">depth {{ [depth - 1, 1] | max }}/{{ node.depth_levels - 1 }}</span>
      {# both controls always render in fixed slots; the unavailable direction
         is present but disabled, so the click targets never move. #}
      {% if depth < node.depth_levels -%}
      <a class="depth-step depth-deeper" href="{{ site.base_path }}/n/{{ node.id }}/d{{ depth + 1 }}/"
         hx-get="{{ site.base_path }}/n/{{ node.id }}/d{{ depth + 1 }}.html" hx-target="#content" hx-swap="outerHTML">&minus; deeper</a>
      {%- else -%}
      <span class="depth-step depth-deeper is-disabled" aria-disabled="true">&minus; deeper</span>
      {%- endif %}
      {% if depth > 2 -%}
      <a class="depth-step depth-shallower" href="{{ site.base_path }}/n/{{ node.id }}/d{{ depth - 1 }}/"
         hx-get="{{ site.base_path }}/n/{{ node.id }}/d{{ depth - 1 }}.html" hx-target="#content" hx-swap="outerHTML">+ surface</a>
      {%- else -%}
      <span class="depth-step depth-shallower is-disabled" aria-disabled="true">+ surface</span>
      {%- endif %}
    </div>
    {% for link in chains %}
    <div class="chain-strip" data-chain-id="{{ link.chain_id }}">
      <span class="chain-title">{{ link.title }}</span>
      <span class="chain-position">{{ link.index }}/{{ link.total }}</span>
      {# both controls always render in fixed slots; the unavailable direction
         is present but disabled, so the click targets never move — mirrors
         the depth dial's discipline above. #}
      {% if link.prev -%}
      <a class="chain-step chain-prev" data-chain-id="{{ link.chain_id }}"
         href="{{ site.base_path }}/n/{{ link.prev }}/"
         hx-get="{{ site.base_path }}/n/{{ link.prev }}/d{{ 2 }}.html" hx-target="#content" hx-swap="outerHTML"
         hx-push-url="{{ site.base_path }}/n/{{ link.prev }}/">&larr; prev</a>
      {%- else -%}
      <span class="chain-step chain-prev is-disabled" aria-disabled="true">&larr; prev</span>
      {%- endif %}
      {% if link.next -%}
      <a class="chain-step chain-next" data-chain-id="{{ link.chain_id }}"
         href="{{ site.base_path }}/n/{{ link.next }}/"
         hx-get="{{ site.base_path }}/n/{{ link.next }}/d{{ 2 }}.html" hx-target="#content" hx-swap="outerHTML"
         hx-push-url="{{ site.base_path }}/n/{{ link.next }}/">next &rarr;</a>
      {%- else -%}
      <span class="chain-step chain-next is-disabled" aria-disabled="true">next &rarr;</span>
      {%- endif %}
    </div>
    {% endfor %}
  </header>

  <div class="layers">
    {% for layer in layers %}
    <section class="layer layer-{{ layer.depth }}" data-depth="{{ layer.depth }}">
      {{ layer.html | safe }}
    </section>
    {% endfor %}
  </div>

  <nav class="neighborhood">
    {% if forward %}
    <section class="hood onward">
      <h2 class="hood-label">onward</h2>
      <ul>
        {% for n in forward %}
        <li><a class="nav-node nav-forward" data-node-id="{{ n.id }}" href="{{ site.base_path }}/n/{{ n.id }}/"
               hx-get="{{ site.base_path }}/n/{{ n.id }}/d{{ 2 }}.html" hx-target="#content" hx-swap="outerHTML"
               hx-push-url="{{ site.base_path }}/n/{{ n.id }}/">&darr; {{ n.title }}</a></li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}
    {% if lateral %}
    <section class="hood lateral">
      <h2 class="hood-label">lateral</h2>
      <ul>
        {% for n in lateral[:10] %}
        <li><a class="nav-node nav-lateral" data-node-id="{{ n.id }}" href="{{ site.base_path }}/n/{{ n.id }}/"
               hx-get="{{ site.base_path }}/n/{{ n.id }}/d{{ 2 }}.html" hx-target="#content" hx-swap="outerHTML"
               hx-push-url="{{ site.base_path }}/n/{{ n.id }}/">&rarr; {{ n.title }}</a></li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}
    {% if backlinks %}
    <section class="hood backlinks">
      <h2 class="hood-label">what points here</h2>
      <ul>
        {% for n in backlinks[:10] %}
        <li><a class="nav-node nav-backlink" data-node-id="{{ n.id }}" href="{{ site.base_path }}/n/{{ n.id }}/"
               hx-get="{{ site.base_path }}/n/{{ n.id }}/d{{ 2 }}.html" hx-target="#content" hx-swap="outerHTML"
               hx-push-url="{{ site.base_path }}/n/{{ n.id }}/">&uarr; {{ n.title }}</a></li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}
  </nav>
</article>
