<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ page_title }}</title>
<link rel="stylesheet" href="{{ site.base_path }}/assets/style.css">
</head>
<body data-base="{{ site.base_path }}">
<header class="site-head">
  <a class="site-name" href="{{ site.base_path }}/">{{ site.title }}</a>
  <span class="site-tagline">{{ site.tagline }}</span>
</header>

<div class="rail" id="rail" aria-label="your path"></div>

<main class="reading">
{{ content | safe }}
</main>

<footer class="action-bar" id="action-bar">
  <span class="key-hint"><kbd>&uarr;</kbd> back</span>
  <span class="key-hint"><kbd>&darr;</kbd> onward</span>
  <span class="key-hint"><kbd>&minus;</kbd> deeper</span>
  <span class="key-hint"><kbd>+</kbd> surface</span>
  <span class="key-hint"><kbd>&rarr;</kbd> branch</span>
  <span class="key-hint"><kbd>&crarr;</kbd> return</span>
  <span class="key-hint"><a href="{{ site.base_path }}/"><kbd>/</kbd> search</a></span>
  <span class="key-hint"><a href="{{ site.base_path }}/help.html"><kbd>?</kbd> help</a></span>
</footer>

<script src="{{ site.base_path }}/assets/htmx.min.js"></script>
<script src="{{ site.base_path }}/assets/app.js"></script>
</body>
</html>
